# Hudhud — environment for docker compose. Copy to `.env` and fill in values:
#   cp .env.example .env
# `.env` is gitignored — never commit real secrets.

# --- PostgreSQL (used by the `db` service and to build DATABASE_URL) ---
POSTGRES_USER=hudhud
POSTGRES_PASSWORD=change-me
POSTGRES_DB=hudhud

# --- Auth (required) ---
# Any long random string; used to sign JWTs.
JWT_SECRET=change-me-to-a-long-random-string

# --- AI / feature API keys (all OPTIONAL — features degrade gracefully) ---
# Arabic text correction
GEMINI_API_KEY=
GEMINI_MODEL=
# AI chat assistant
OPENROUTER_API_KEY=
# Content moderation
OPENAI_API_KEY=
# Real-time speech-to-text
DEEPGRAM_API_KEY=
DEEPGRAM_LANGUAGE=
DEEPGRAM_MODEL=

# --- Cloudinary (file uploads / chat & task attachments) ---
# Either set CLOUDINARY_URL, or the three discrete vars below.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Image reverse-search & AI/deepfake detection ---
SERPAPI_API_KEY=
SERPER_API_KEY=
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
SCAMAI_API_KEY=
SCAMAI_API_URL=

# --- Domain safety check ---
GOOGLE_SAFE_BROWSING_API_KEY=

# --- Email (invites / notifications, optional) ---
ETHEREAL_API_KEY=
