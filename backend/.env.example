# ====== Hudhud Toolkit — backend environment ======
# Copy this file to ".env" and fill in your free API keys.

# Server
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string

# Google Gemini (article grammar/terminology correction)
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-lite-latest

# OpenRouter (multi-model chat box)
# Get a free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI (content moderation — the moderation endpoint is free)
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Deepgram (speech-to-text — Arabic / Palestinian dialect, for voice dictation)
# Free $200 credit, no card. Get a key at: https://console.deepgram.com
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=ar

# SerpApi (reverse image search — Google Lens EXACT matches / provenance)
# RECOMMENDED for "where was this exact image published". Free ~250/month.
# Get a key at: https://serpapi.com/manage-api-key
SERPAPI_API_KEY=

# Serper.dev (fallback — visual/similar matches only, not exact provenance)
# Free 2,500 searches/month. Get a key at: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# AI-image detection — RECOMMENDED: Sightengine (free 2,000 ops/mo, documented)
# Get free api_user + api_secret at: https://sightengine.com
SIGHTENGINE_API_USER=your_sightengine_api_user_here
SIGHTENGINE_API_SECRET=your_sightengine_api_secret_here

# Alternative: ScamAI (auth via x-api-key). Its detect endpoint is only shown in
# the logged-in dashboard — put that exact URL in SCAMAI_API_URL to enable it.
SCAMAI_API_KEY=your_scamai_api_key_here
SCAMAI_MODEL=eva-v1-fast

# Cloudinary (file uploads for team tasks)
# Get API key and secret from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email notifications (nodemailer)
# SMTP configuration for sending invitation emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Toggle: if a key is missing, the related feature degrades gracefully
# (the app still runs; that step is skipped with a clear notice).
